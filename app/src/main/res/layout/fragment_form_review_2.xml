<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ui.review.FormReviewFragment2">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#666666" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:text="Write your review"
            android:textColor="#FF6B00"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvStep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:text="2/3"
            android:textColor="#FF6B00"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainReview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingLeft="20dp"
        android:paddingEnd="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/btnNextStep"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#E9E4E4"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E9E4E4"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Section Ilmu Baru -->
                <TextView
                    style="@style/LabelForm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ilmu Baru Yang Didapat"
                    android:textColor="#333333" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgSkills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:chipSpacingHorizontal="8dp">

                    <!-- Contoh Chip (Nanti diisi lewat logic) -->
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Figma"
                        android:textColor="@color/pure_white"
                        app:chipBackgroundColor="#FF6B00"
                        app:chipCornerRadius="12dp"
                        app:closeIconTint="@color/pure_white"
                        app:closeIconVisible="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/btnAddSkill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add +"
                        android:textColor="#FF6B00"
                        app:chipBackgroundColor="#E8EFFF"
                        app:chipCornerRadius="12dp"
                        app:chipStrokeWidth="0dp" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Section Pro -->
                <TextView
                    style="@style/LabelForm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Pro"
                    android:textColor="#333333" />

                <EditText
                    android:id="@+id/etPro"
                    style="@style/InputForm"
                    android:layout_height="120dp"
                    android:gravity="top"
                    android:hint="enter your review"
                    android:paddingTop="16dp" />

                <!-- Section Kontra -->
                <TextView
                    style="@style/LabelForm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Kontra"
                    android:textColor="#333333" />

                <EditText
                    android:id="@+id/etKontra"
                    style="@style/InputForm"
                    android:layout_height="120dp"
                    android:gravity="top"
                    android:hint="enter your review"
                    android:paddingTop="16dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNextStep"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:backgroundTint="#FF6B00"
        android:fontFamily="@font/poppins_bold"
        android:text="Next Step"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>