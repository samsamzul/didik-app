<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_orange">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="80dp"
        android:background="@drawable/bg_white_rounded"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:text="@string/tRegister"
            android:textColor="@color/brand_orange"
            android:textSize="28sp"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/tFullName"
            android:textColor="@color/deep_black"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tRegister" />

        <EditText
            android:id="@+id/etRegisterName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input_rounded"
            android:fontFamily="@font/poppins"
            android:hint="@string/plcFullName"
            android:inputType="textPersonName"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/tFullName" />

        <TextView
            android:id="@+id/tRegisterEmailLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/tEmail"
            android:textColor="@color/deep_black"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/etRegisterName" />

        <EditText
            android:id="@+id/etRegisterEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input_rounded"
            android:fontFamily="@font/poppins"
            android:hint="@string/plcUsername"
            android:inputType="textEmailAddress"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/tRegisterEmailLabel" />

        <TextView
            android:id="@+id/tInstansiLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/tInstansi"
            android:textColor="@color/deep_black"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/etRegisterEmail" />

        <EditText
            android:id="@+id/etRegisterInstansi"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input_rounded"
            android:fontFamily="@font/poppins"
            android:hint="@string/plcInstansi"
            android:inputType="text"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/tInstansiLabel" />

        <TextView
            android:id="@+id/tRegisterPassLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/tPassword"
            android:textColor="@color/deep_black"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/etRegisterInstansi" />

        <EditText
            android:id="@+id/etRegisterPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input_rounded"
            android:fontFamily="@font/poppins"
            android:hint="@string/plcPassword"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@+id/tRegisterPassLabel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            android:layout_width="140dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            app:backgroundTint="@color/brand_orange"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/btnRegister"
            android:textAllCaps="false"
            android:textColor="@color/pure_white"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/etRegisterPassword" />

        <TextView
            android:id="@+id/tvToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/poppins"
            android:padding="8dp"
            android:text="Sudah punya akun? Masuk di sini"
            android:textColor="@color/hint_grey"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnRegister" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>