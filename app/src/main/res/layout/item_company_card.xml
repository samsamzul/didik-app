<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivCompany"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="#0052FF"
                android:padding="8dp"
                android:src="@drawable/ic_company"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_pill_orange"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Placeholder"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="@font/poppins" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Product Design Intern"
            android:textColor="#121212"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCompany"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/poppins"
            android:text="Figma - San Fransisco, CA"
            android:textColor="#9E9E9E"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_soft"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Figma"
                android:textColor="#FF6B00"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_pill_soft"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Figma"
                android:textColor="#FF6B00"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
