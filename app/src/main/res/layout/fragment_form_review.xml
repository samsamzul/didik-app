<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="Write Your Review"
                android:textColor="#FF6B00"
                android:textSize="22sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="1/3"
                android:textColor="#FF6B00"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#E9E4E4"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/LabelForm"
                    android:text="Company Name" />

                <EditText
                    android:id="@+id/etCompanyName"
                    style="@style/InputForm"
                    android:hint="e.g. Google" />

                <TextView
                    style="@style/LabelForm"
                    android:layout_marginTop="16dp"
                    android:text="Position" />

                <EditText
                    android:id="@+id/etPosition"
                    style="@style/InputForm"
                    android:hint="e.g. UI/UX Intern" />

                <TextView
                    style="@style/LabelForm"
                    android:layout_marginTop="16dp"
                    android:text="Your Review" />

                <EditText
                    android:id="@+id/etReviewText"
                    style="@style/InputForm"
                    android:layout_height="150dp"
                    android:gravity="top"
                    android:hint="Share your experience..."
                    android:paddingTop="12dp" />

                <TextView
                    style="@style/LabelForm"
                    android:layout_marginTop="16dp"
                    android:text="Rating" />

                <RatingBar
                    android:id="@+id/rbReview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:numStars="5"
                    android:progressTint="#FF6B00"
                    android:stepSize="1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <!-- Culture -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/icCulture"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Culture Icon"
                            android:src="@drawable/ic_profile"
                            app:tint="#121212" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_toEndOf="@id/icCulture"
                            android:fontFamily="@font/poppins"
                            android:text="Culture"
                            android:textColor="#121212"
                            android:textSize="13sp" />

                        <RatingBar
                            android:id="@+id/rbCulture"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:numStars="5"
                            android:progressTint="#FF6B00"
                             />
                    </RelativeLayout>

                    <!-- Workload -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/icWorkload"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Workload Icon"
                            android:src="@drawable/ic_job_desc"
                            app:tint="#121212" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_toEndOf="@id/icWorkload"
                            android:fontFamily="@font/poppins"
                            android:text="Workload"
                            android:textColor="#121212"
                            android:textSize="13sp" />

                        <RatingBar
                            android:id="@+id/rbWorkload"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:numStars="5"
                            android:progressTint="#FF6B00" />
                    </RelativeLayout>

                    <!-- Mentorship -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/icMentorship"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Mentorship Icon"
                            android:src="@drawable/ic_history"
                            app:tint="#121212" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_toEndOf="@id/icMentorship"
                            android:fontFamily="@font/poppins"
                            android:text="Mentorship"
                            android:textColor="#121212"
                            android:textSize="13sp" />

                        <RatingBar
                            android:id="@+id/rbMentorship"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:numStars="5"
                            android:progressTint="#FF6B00"
                            />
                    </RelativeLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="#FF6B00"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Next"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
