<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:text="Write a Review"
            android:textColor="#FF6B00"
            android:textSize="22sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/LabelForm"
                    android:text="Company Name" />

                <EditText
                    android:id="@+id/etCompanyName"
                    style="@style/InputForm"
                    android:hint="e.g. Google" />

                <TextView
                    style="@style/LabelForm"
                    android:layout_marginTop="16dp"
                    android:text="Position" />

                <EditText
                    android:id="@+id/etPosition"
                    style="@style/InputForm"
                    android:hint="e.g. UI/UX Intern" />

                <TextView
                    style="@style/LabelForm"
                    android:layout_marginTop="16dp"
                    android:text="Your Review" />

                <EditText
                    android:id="@+id/etReviewText"
                    style="@style/InputForm"
                    android:layout_height="150dp"
                    android:gravity="top"
                    android:hint="Share your experience..."
                    android:paddingTop="12dp" />

                <TextView
                    style="@style/LabelForm"
                    android:layout_marginTop="16dp"
                    android:text="Rating" />

                <RatingBar
                    android:id="@+id/rbReview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:numStars="5"
                    android:progressTint="#FF6B00"
                    android:stepSize="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="32dp"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Submit Review"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#FF6B00" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
